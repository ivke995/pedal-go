TURSO_DATABASE_URL=file:./local.db
# Required for remote Turso databases. Leave unset for local file: URLs.
# TURSO_AUTH_TOKEN=
# For remote Turso, copy this file to .env.local and set your real URL/token there.

# Required when running `pnpm db:seed` for the bootstrap admin user.
ADMIN_BOOTSTRAP_PASSWORD=change-me-before-seeding
# Optional seed overrides.
# ADMIN_BOOTSTRAP_EMAIL=admin@pedalgo.local
# ADMIN_BOOTSTRAP_NAME=PedalGo Admin

# Required to create Stripe Checkout sessions for public bookings.
STRIPE_SECRET_KEY=sk_test_change_me
# Required to verify Stripe webhook events from Stripe CLI or Dashboard endpoint.
STRIPE_WEBHOOK_SECRET=whsec_change_me
# Used for Stripe Checkout success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required to send webhook-confirmed booking confirmation emails with Resend.
RESEND_API_KEY=re_change_me
# Sender must be verified in Resend for real delivery.
RESEND_FROM_EMAIL="PedalGo <bookings@pedalgo.example>"

# Confirmation email business copy. Defaults match current public-site copy when unset.
PEDALGO_PICKUP_LOCATION="PedalGo, Obala Kulina bana 12, Sarajevo"
PEDALGO_CONTACT_EMAIL=hello@pedalgo.example
PEDALGO_CONTACT_PHONE="+387 33 000 000"
PEDALGO_SUPPORT_HOURS="Mon–Sun · 08:00 – 20:00"
PEDALGO_PICKUP_INSTRUCTIONS="Bring your reservation number and a valid photo ID. Look for the green PedalGo sign at the central riverside shop."
